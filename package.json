{
  "name": "web-vuln-scanner",
  "version": "1.0.0",
  "description": "HTTP-based web vulnerability scanner CLI built with Node.js and TypeScript",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "webscan": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "security",
    "scanner",
    "cli",
    "typescript",
    "web",
    "vulnerability"
  ],
  "dependencies": {
    "axios": "^1.8.4",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "ora": "^5.4.1",
    "p-limit": "^3.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
